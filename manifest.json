{\n  "manifest_version": 3,\n  "name": "Nate's Stock Tracker",\n  "version": "1.0.0",\n  "description": "Advanced TradingView tracker with real-time Claude AI analysis and comprehensive market data extraction",\n  "permissions": [\n    "activeTab",\n    "scripting",\n    "tabs",\n    "storage"\n  ],\n  "host_permissions": [\n    "https://www.tradingview.com/*",\n    "https://api.anthropic.com/*"\n  ],\n  "action": {\n    "default_title": "Nate's Stock Tracker",\n    "default_popup": "popup.html"\n  },\n  "background": {\n    "service_worker": "background.js"\n  },\n  "content_scripts": [\n    {\n      "matches": ["https://www.tradingview.com/*"],\n      "js": ["content.js"],\n      "run_at": "document_start",\n      "all_frames": true\n    }\n  ],\n  "side_panel": {\n    "default_path": "sidepanel.html"\n  },\n  "commands": {\n    "toggle-side-panel": {\n      "suggested_key": "Ctrl+Shift+Y",\n      "description": "Toggle Nate's Stock Tracker side panel"\n    }\n  }\n}